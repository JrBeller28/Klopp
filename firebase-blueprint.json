{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Menu items for the cafe",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product" },
        "description": { "type": "string", "description": "Description of the product" },
        "price": { "type": "number", "description": "Price in Rupiah" },
        "imageUrl": { "type": "string", "description": "URL or path to the product image" },
        "category": { "type": "string", "description": "Category of the product (e.g., Coffee, Snack)" },
        "stock": { "type": "number", "description": "Available stock" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "price", "category"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "Table reservations made by customers",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer name" },
        "email": { "type": "string", "format": "email", "description": "Customer email" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "date": { "type": "string", "description": "Reservation date (YYYY-MM-DD)" },
        "time": { "type": "string", "description": "Reservation time (HH:MM)" },
        "guests": { "type": "number", "description": "Number of guests" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"], "description": "Status of the reservation" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "phone", "date", "time", "guests", "status"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of cafe menu products"
    },
    "/reservations/{reservationId}": {
      "schema": "Reservation",
      "description": "Collection of customer reservations"
    }
  }
}
